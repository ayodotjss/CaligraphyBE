PORT=3001
NODE_ENV=development

RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0xYourDeployedContract
CHAIN_ID=31337
SIGNER_PRIVATE_KEY=0xYourBackendSignerPrivateKey

